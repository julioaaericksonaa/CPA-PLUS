+func (s *Store) InsertCodexInspectionResult(ctx context.Context, result CodexInspectionResult) (CodexInspectionResult, error) {
+	if result.CreatedAtMS <= 0 {
+		result.CreatedAtMS = time.Now().UnixMilli()
