+func (s *Service) acquireRun() error {
+	s.mu.Lock()
+	defer s.mu.Unlock()
+	if s.running {
+		return ErrRunAlreadyActive
+	}
+	s.running = true
+	return nil
+}
+
+func (s *Service) releaseRun() {
+	s.mu.Lock()
+	defer s.mu.Unlock()
+	s.running = false
+}
