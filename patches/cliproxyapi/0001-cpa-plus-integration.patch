@@ -12,4 +12,68 @@ var (
 
 	// BuildDate records when the binary was built in UTC.
 	BuildDate = "unknown"
+
+	// CLIUpstreamVersion is the CLIProxyAPI upstream tag/ref baked into CPA-PLUS builds.
+	CLIUpstreamVersion = ""
+
+	// CLIUpstreamCommit is the CLIProxyAPI upstream commit baked into CPA-PLUS builds.
+	CLIUpstreamCommit = ""
+
+	// PlusUpstreamVersion is the CPA-Manager-Plus upstream tag/ref baked into CPA-PLUS builds.
+	PlusUpstreamVersion = ""
+
+	// PlusUpstreamCommit is the CPA-Manager-Plus upstream commit baked into CPA-PLUS builds.
+	PlusUpstreamCommit = ""
 )
+
+// ServerVersion returns the user-facing server version. CPA-PLUS integrated
+// builds intentionally expose the upstream CLIProxyAPI version instead of the
+// private CPA-PLUS build version.
+func ServerVersion() string {
+	if trimmed := trim(CLIUpstreamVersion); trimmed != "" {
+		return trimmed
+	}
+	return trim(Version)
+}
+
+// ServerCommit returns the short upstream CLIProxyAPI commit for display.
+func ServerCommit() string {
+	return shortCommit(CLIUpstreamCommit)
+}
+
+// ManagerVersion returns the user-facing manager panel version. CPA-Manager-Plus
+// may not publish release tags, so the upstream commit is the stable fallback.
+func ManagerVersion() string {
+	if trimmed := trim(PlusUpstreamVersion); trimmed != "" {
+		return trimmed
+	}
+	if commit := shortCommit(PlusUpstreamCommit); commit != "" {
+		return commit
+	}
+	return "dev"
+}
+
+// ManagerCommit returns the short upstream CPA-Manager-Plus commit for display.
+func ManagerCommit() string {
+	return shortCommit(PlusUpstreamCommit)
+}
+
+func shortCommit(value string) string {
+	trimmed := trim(value)
+	if len(trimmed) > 8 {
+		return trimmed[:8]
+	}
+	return trimmed
+}
+
+func trim(value string) string {
+	start := 0
+	end := len(value)
+	for start < end && (value[start] == ' ' || value[start] == '\t' || value[start] == '\n' || value[start] == '\r') {
+		start++
+	}
+	for end > start && (value[end-1] == ' ' || value[end-1] == '\t' || value[end-1] == '\n' || value[end-1] == '\r') {
+		end--
+	}
+	return value[start:end]
+}
