+	r.ServeHTTP(getW, getReq)
+	if getW.Code != http.StatusOK {
+		t.Fatalf("GET status code = %d, want 200; body=%s", getW.Code, getW.Body.String())
+	}
+	if !strings.Contains(getW.Body.String(), `"intervalMinutes":15`) || !strings.Contains(getW.Body.String(), `"autoActionMode":"disable"`) {
+		t.Fatalf("saved codex inspection config not returned: %s", getW.Body.String())
+	}
+	if strings.Contains(getW.Body.String(), "internal-management-key") {
+		t.Fatalf("response leaked internal management key: %s", getW.Body.String())
+	}
+}
