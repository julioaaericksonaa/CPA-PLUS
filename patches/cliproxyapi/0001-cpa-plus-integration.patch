+func TestCodexInspectionRoutesRunAndPersistHistory(t *testing.T) {
+	gin.SetMode(gin.TestMode)
+	var sawManagementAuth bool
+	upstream := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
+		if r.Header.Get("Authorization") == "Bearer internal-management-key" {
+			sawManagementAuth = true
+		}
+		switch {
+		case r.URL.Path == "/auth-files" && r.Method == http.MethodGet:
+			_, _ = w.Write([]byte(`{"files":[{"name":"auth-a.json","auth_index":"auth-1","provider":"codex","account":"alice@example.com","status":"ok","state":"ready"}]}`))
+		case r.URL.Path == "/api-call" && r.Method == http.MethodPost:
+			_, _ = w.Write([]byte(`{"status_code":200,"body":{"ok":true}}`))
+		default:
+			http.NotFound(w, r)
+		}
+	}))
+	defer upstream.Close()
+
+	s, err := store.Open(filepath.Join(t.TempDir(), "usage.sqlite"))
+	if err != nil {
+		t.Fatalf("store.Open() error = %v", err)
+	}
+	defer s.Close()
+	managerSvc := managerconfig.New(nil, s, upstream.URL, "internal-management-key")
+	inspectionSvc := codexinspection.New(s, managerSvc)
+
+	r := gin.New()
+	RegisterCodexInspectionRoutes(r.Group("/v0/management"), Options{Enabled: true, CodexInspection: inspectionSvc})
+
+	runReq := httptest.NewRequest(http.MethodPost, "/v0/management/codex-inspection/run", nil)
+	runW := httptest.NewRecorder()
+	r.ServeHTTP(runW, runReq)
+	if runW.Code != http.StatusOK {
+		t.Fatalf("run status code = %d, want 200; body=%s", runW.Code, runW.Body.String())
+	}
+	if !sawManagementAuth {
+		t.Fatal("inspection did not call upstream with internal management key")
+	}
+
+	listReq := httptest.NewRequest(http.MethodGet, "/v0/management/codex-inspection/runs?limit=30", nil)
+	listW := httptest.NewRecorder()
+	r.ServeHTTP(listW, listReq)
