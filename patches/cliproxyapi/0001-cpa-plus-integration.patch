+			c.JSON(http.StatusServiceUnavailable, gin.H{"error": "codex inspection service unavailable"})
+			return
+		}
+		limit := 20
+		if raw := strings.TrimSpace(c.Query("limit")); raw != "" {
+			if parsed, err := strconv.Atoi(raw); err == nil && parsed > 0 {
+				limit = parsed
+			}
+		}
