new file mode 100644
index 00000000..8d7f0647
--- /dev/null
+++ b/internal/plusmanager/managerconfig/service.go
@@ -0,0 +1,150 @@
+package managerconfig
+
+import (
+	"context"
+	"errors"
+	"strings"
+	"time"
+
+	proxyconfig "github.com/router-for-me/CLIProxyAPI/v7/internal/config"
+	"github.com/router-for-me/CLIProxyAPI/v7/internal/plusmanager/cpa"
+	"github.com/router-for-me/CLIProxyAPI/v7/internal/plusmanager/model"
+	"github.com/router-for-me/CLIProxyAPI/v7/internal/plusmanager/store"
+)
+
+type Source string
+
+const (
+	SourceNone       Source = ""
+	SourceIntegrated Source = "integrated"
+	SourceDB         Source = "db"
+)
+
+type Response struct {
+	Config   store.ManagerConfig `json:"config"`
+	Source   string              `json:"source"`
+	CPAUsage *cpa.UsageConfig    `json:"cpaUsage,omitempty"`
+}
+
+type Service struct {
+	cfg                   *proxyconfig.Config
+	store                 *store.Store
+	internalBaseURL       string
+	internalManagementKey string
+}
+
+func New(cfg *proxyconfig.Config, st *store.Store, internalBaseURL, internalManagementKey string) *Service {
+	return &Service{cfg: cfg, store: st, internalBaseURL: internalBaseURL, internalManagementKey: internalManagementKey}
+}
+
+func (s *Service) Get(ctx context.Context) (Response, error) {
+	cfg, source, _, err := s.ResolveManagerConfigWithSource(ctx)
+	if err != nil {
+		return Response{}, err
+	}
+	return Response{
+		Config: cfg,
+		Source: string(source),
+		CPAUsage: &cpa.UsageConfig{
+			UsageStatisticsEnabled:          true,
+			RedisUsageQueueRetentionSeconds: 60,
+			RetentionSourceDefault:          true,
+		},
+	}, nil
+}
+
+func (s *Service) Update(ctx context.Context, submitted store.ManagerConfig) (Response, error) {
+	current, _, _, err := s.ResolveManagerConfigWithSource(ctx)
+	if err != nil {
+		return Response{}, err
+	}
+	if err := model.ValidateCodexInspectionConfig(submitted.CodexInspection); err != nil {
+		return Response{}, err
+	}
+	next := s.MergeSubmittedManagerConfig(current, submitted)
+	next.CPAConnection.CPABaseURL = "integrated"
+	next.CPAConnection.ManagementKey = "integrated"
+	if s.store != nil {
+		if err := s.store.SaveManagerConfig(ctx, next); err != nil {
+			return Response{}, err
+		}
+	}
+	return Response{Config: next, Source: string(SourceDB)}, nil
+}
+
+func (s *Service) ResolveManagerConfigWithSource(ctx context.Context) (store.ManagerConfig, Source, bool, error) {
+	cfg := s.DefaultManagerConfig()
+	source := SourceIntegrated
+	found := true
+	if s.store != nil {
+		if saved, ok, err := s.store.LoadManagerConfig(ctx); err != nil {
+			return cfg, source, false, err
+		} else if ok {
+			cfg = s.MergeSubmittedManagerConfig(cfg, saved)
+			source = SourceDB
+			found = true
+		}
+	}
+	cfg.CPAConnection.CPABaseURL = "integrated"
+	cfg.CPAConnection.ManagementKey = "integrated"
+	return cfg, source, found, nil
+}
+
+func (s *Service) ResolveRuntime(ctx context.Context) (store.ManagerConfig, store.Setup, bool, error) {
+	cfg, _, found, err := s.ResolveManagerConfigWithSource(ctx)
+	if err != nil || !found {
+		return cfg, store.Setup{}, found, err
+	}
+	base := cpa.NormalizeBaseURL(s.internalBaseURL)
+	key := strings.TrimSpace(s.internalManagementKey)
+	if base == "" || key == "" {
+		return cfg, store.Setup{}, false, errors.New("integrated management endpoint is not ready")
+	}
+	return cfg, store.Setup{CPAUpstreamURL: base, ManagementKey: key, Queue: "redisqueue", PopSide: "left"}, true, nil
+}
+
+func (s *Service) DefaultManagerConfig() store.ManagerConfig {
+	pollIntervalMS := 1000
+	if s != nil && s.cfg != nil && s.cfg.PlusManager.PollIntervalMs > 0 {
+		pollIntervalMS = s.cfg.PlusManager.PollIntervalMs
+	}
+	return store.ManagerConfig{
+		CPAConnection: store.ManagerCPAConnectionConfig{CPABaseURL: "integrated", ManagementKey: "integrated"},
+		Collector: store.ManagerCollectorConfig{
+			Enabled:        BoolPtr(true),
+			CollectorMode:  "auto",
+			Queue:          "redisqueue",
+			PopSide:        "left",
+			BatchSize:      100,
+			PollIntervalMS: pollIntervalMS,
+			QueryLimit:     50000,
+		},
+		CodexInspection:      store.DefaultCodexInspectionConfig(),
+		ExternalUsageService: store.ManagerExternalUsageServiceConfig{Enabled: false, ServiceBase: ""},
+	}
+}
+
+func (s *Service) MergeSubmittedManagerConfig(base store.ManagerConfig, submitted store.ManagerConfig) store.ManagerConfig {
+	next := base
+	if submitted.Collector.Enabled != nil {
+		next.Collector.Enabled = BoolPtr(*submitted.Collector.Enabled)
+	}
+	if submitted.Collector.CollectorMode != "" {
+		next.Collector.CollectorMode = strings.TrimSpace(submitted.Collector.CollectorMode)
+	}
+	if submitted.Collector.BatchSize > 0 {
+		next.Collector.BatchSize = submitted.Collector.BatchSize
+	}
+	if submitted.Collector.PollIntervalMS > 0 {
+		next.Collector.PollIntervalMS = submitted.Collector.PollIntervalMS
+	}
+	if submitted.Collector.QueryLimit > 0 {
+		next.Collector.QueryLimit = submitted.Collector.QueryLimit
+	}
+	next.CodexInspection = model.NormalizeCodexInspectionConfig(submitted.CodexInspection, base.CodexInspection)
+	next.ExternalUsageService = store.ManagerExternalUsageServiceConfig{Enabled: false, ServiceBase: ""}
+	next.UpdatedAtMS = time.Now().UnixMilli()
+	return next
+}
+
+func BoolPtr(value bool) *bool { return &value }
