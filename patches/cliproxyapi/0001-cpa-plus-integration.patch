+		}
+		c.JSON(http.StatusOK, gin.H{"items": runs})
+	})
+	group.POST("/codex-inspection/run", func(c *gin.Context) {
+		if opts.CodexInspection == nil {
+			c.JSON(http.StatusServiceUnavailable, gin.H{"error": "codex inspection service unavailable"})
+			return
+		}
+		result, err := opts.CodexInspection.Run(context.WithoutCancel(c.Request.Context()), codexinspection.RunRequest{TriggerType: "manual", TriggerKey: "manual"})
+		if err != nil {
+			c.JSON(codexInspectionErrorStatus(err), gin.H{"error": err.Error()})
+			return
+		}
+		c.JSON(http.StatusOK, result)
+	})
+	group.GET("/codex-inspection/runs/:id", func(c *gin.Context) {
+		if opts.CodexInspection == nil {
+			c.JSON(http.StatusServiceUnavailable, gin.H{"error": "codex inspection service unavailable"})
+			return
+		}
+		id, err := strconv.ParseInt(c.Param("id"), 10, 64)
+		if err != nil || id <= 0 {
+			c.JSON(http.StatusBadRequest, gin.H{"error": "run id is required"})
+			return
+		}
+		detail, err := opts.CodexInspection.GetRun(c.Request.Context(), id)
+		if err != nil {
+			c.JSON(codexInspectionErrorStatus(err), gin.H{"error": err.Error()})
+			return
+		}
+		c.JSON(http.StatusOK, detail)
+	})
+	group.POST("/codex-inspection/runs/:id/actions", func(c *gin.Context) {
+		if opts.CodexInspection == nil {
+			c.JSON(http.StatusServiceUnavailable, gin.H{"error": "codex inspection service unavailable"})
+			return
+		}
+		id, err := strconv.ParseInt(c.Param("id"), 10, 64)
+		if err != nil || id <= 0 {
+			c.JSON(http.StatusBadRequest, gin.H{"error": "run id is required"})
+			return
+		}
+		var req codexinspection.ExecuteActionsRequest
+		if err := c.ShouldBindJSON(&req); err != nil {
+			c.JSON(http.StatusBadRequest, gin.H{"error": "invalid JSON"})
+			return
+		}
+		result, err := opts.CodexInspection.ExecuteManualActions(c.Request.Context(), id, req)
+		if err != nil {
+			c.JSON(codexInspectionErrorStatus(err), gin.H{"error": err.Error()})
+			return
+		}
+		c.JSON(http.StatusOK, result)
+	})
+}
+
+func codexInspectionErrorStatus(err error) int {
+	switch {
+	case errors.Is(err, codexinspection.ErrRunNotFound):
+		return http.StatusNotFound
+	case errors.Is(err, codexinspection.ErrRunAlreadyActive), errors.Is(err, codexinspection.ErrRunNotCompleted):
+		return http.StatusConflict
+	case errors.Is(err, codexinspection.ErrNotConfigured):
+		return http.StatusPreconditionFailed
+	case errors.Is(err, codexinspection.ErrActionIDsRequired), errors.Is(err, codexinspection.ErrNoActionableResults):
+		return http.StatusBadRequest
+	default:
+		return http.StatusInternalServerError
+	}
+}
