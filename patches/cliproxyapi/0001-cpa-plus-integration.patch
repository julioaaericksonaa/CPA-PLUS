+	outcomes = append(outcomes, s.executeActionItems(ctx, setup, settings, items, logger, "Ķć¬ÕŖ©ÕżäńÉå", func(item model.CodexInspectionResult) string {
+		return resolveExecutableAction(mode, item.Action)
+	})...)
