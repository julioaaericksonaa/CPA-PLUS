+package buildinfo
+
+import "testing"
+
+func TestServerVersionUsesCLIUpstreamWhenAvailable(t *testing.T) {
+	oldVersion, oldCommit := Version, Commit
+	oldCLIVersion, oldCLICommit := CLIUpstreamVersion, CLIUpstreamCommit
+	t.Cleanup(func() {
+		Version, Commit = oldVersion, oldCommit
+		CLIUpstreamVersion, CLIUpstreamCommit = oldCLIVersion, oldCLICommit
+	})
+
+	Version = "v7.1.54-plus.9"
+	Commit = "private-plus"
+	CLIUpstreamVersion = "v7.1.54"
+	CLIUpstreamCommit = "07c607b7abcdef"
+
+	if got, want := ServerVersion(), "v7.1.54"; got != want {
+		t.Fatalf("ServerVersion() = %q, want %q", got, want)
+	}
+	if got, want := ServerCommit(), "07c607b7"; got != want {
+		t.Fatalf("ServerCommit() = %q, want %q", got, want)
+	}
+}
+
+func TestManagerVersionUsesPlusUpstreamCommit(t *testing.T) {
+	oldPlusVersion, oldPlusCommit := PlusUpstreamVersion, PlusUpstreamCommit
+	t.Cleanup(func() {
+		PlusUpstreamVersion, PlusUpstreamCommit = oldPlusVersion, oldPlusCommit
+	})
+
+	PlusUpstreamVersion = ""
+	PlusUpstreamCommit = "5ee6e23abcdef"
+
+	if got, want := ManagerVersion(), "5ee6e23a"; got != want {
+		t.Fatalf("ManagerVersion() = %q, want %q", got, want)
+	}
+}
+
+func TestManagerVersionUsesPlusTagAndCommitVersion(t *testing.T) {
+	oldPlusVersion, oldPlusCommit := PlusUpstreamVersion, PlusUpstreamCommit
+	t.Cleanup(func() {
+		PlusUpstreamVersion, PlusUpstreamCommit = oldPlusVersion, oldPlusCommit
+	})
+
+	PlusUpstreamVersion = "v1.4.1+b4c93d13"
+	PlusUpstreamCommit = "b4c93d138d9ca001b0b2243d8eda53a745f97e34"
+
+	if got, want := ManagerVersion(), "v1.4.1+b4c93d13"; got != want {
+		t.Fatalf("ManagerVersion() = %q, want %q", got, want)
+	}
+	if got, want := ManagerCommit(), "b4c93d13"; got != want {
+		t.Fatalf("ManagerCommit() = %q, want %q", got, want)
+	}
+}
