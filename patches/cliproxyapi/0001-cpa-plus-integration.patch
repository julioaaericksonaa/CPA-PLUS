+	}
+	c.JSON(http.StatusOK, provider.Status())
+}
+
+func RegisterCompatibilityRoutes(engine *gin.Engine, opts Options) {
+	if engine == nil || !opts.Enabled {
+		return
+	}
+	engine.GET("/usage-service/info", func(c *gin.Context) {
+		c.JSON(http.StatusOK, gin.H{
+			"service":            "cpa-manager-plus",
+			"mode":               "integrated",
+			"configured":         true,
+			"projectInitialized": true,
+			"setupRequired":      false,
+			"adminReady":         true,
+			"dataKeyReady":       true,
+		})
+	})
+	engine.GET("/status", func(c *gin.Context) {
+		c.JSON(http.StatusOK, gin.H{
+			"service": "cpa-manager-plus",
+			"mode":    "integrated",
+		})
+	})
+	configHandlers := append([]gin.HandlerFunc{}, opts.Auth...)
+	configHandlers = append(configHandlers, func(c *gin.Context) {
+		if opts.ManagerConfig == nil {
+			c.JSON(http.StatusOK, integratedManagerConfigResponse(c.Request.Context(), nil))
+			return
+		}
+		if c.Request.Method == http.MethodPut {
+			var req struct {
+				Config store.ManagerConfig `json:"config"`
+			}
+			if err := c.ShouldBindJSON(&req); err != nil {
+				c.JSON(http.StatusBadRequest, gin.H{"error": "invalid JSON"})
