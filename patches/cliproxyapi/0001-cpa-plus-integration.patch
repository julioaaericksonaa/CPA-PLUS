+// PostCPAPlusUpdate starts a local CPA-PLUS release update when the published
+// latest Release binary differs from the currently installed binary.
+func (h *Handler) PostCPAPlusUpdate(c *gin.Context) {
+	appDir := h.cpaPlusAppDir()
+	binaryPath := filepath.Join(appDir, "cli-proxy-api")
+	client := h.latestVersionHTTPClient()
+	req, err := http.NewRequestWithContext(c.Request.Context(), http.MethodGet, cpaPlusReleaseSHAURL, nil)
+	if err != nil {
+		c.JSON(http.StatusInternalServerError, gin.H{"error": "request_create_failed", "message": err.Error()})
+		return
+	}
+	req.Header.Set("Accept", "text/plain,*/*")
+	req.Header.Set("User-Agent", latestReleaseUserAgent)
+
+	resp, err := client.Do(req)
+	if err != nil {
+		c.JSON(http.StatusBadGateway, gin.H{"error": "release_check_failed", "message": err.Error()})
+		return
+	}
+	defer func() {
+		if errClose := resp.Body.Close(); errClose != nil {
+			log.WithError(errClose).Debug("failed to close CPA-PLUS release sha response body")
+		}
+	}()
+
+	body, _ := io.ReadAll(io.LimitReader(resp.Body, 4096))
+	if resp.StatusCode != http.StatusOK {
+		c.JSON(http.StatusBadGateway, gin.H{"error": "release_check_failed", "message": fmt.Sprintf("status %d: %s", resp.StatusCode, strings.TrimSpace(string(body)))})
+		return
+	}
+
+	changed, currentSHA, err := cpaPlusReleaseChanged(binaryPath, string(body))
+	if err != nil {
+		c.JSON(http.StatusInternalServerError, gin.H{"error": "local_binary_check_failed", "message": err.Error()})
 		return
 	}
+	if !changed {
+		c.JSON(cpaPlusReleaseNotReadyHTTPStatus(), gin.H{
+			"status":       "release_not_ready",
+			"message":      "latest Release 尚未包含该上游更新，请等待每日 21:00 自动合并发布后再更新",
+			"current_sha":  currentSHA,
+			"release_sha":  releaseSHAFromText(string(body)),
+			"next_publish": "21:00 Asia/Shanghai",
+		})
+		return
+	}
+	if !globalCPAPlusUpdateState.tryStart() {
+		c.JSON(http.StatusConflict, gin.H{"status": "update_running", "message": "CPA-PLUS 更新已在后台运行，请稍后刷新页面"})
+		return
+	}
+
+	go func() {
+		defer globalCPAPlusUpdateState.finish()
+		logPath := filepath.Join(appDir, "logs", "cpa-plus-update.log")
+		var logFile *os.File
+		if errMkdir := os.MkdirAll(filepath.Dir(logPath), 0o755); errMkdir == nil {
+			if f, errOpen := os.OpenFile(logPath, os.O_CREATE|os.O_WRONLY|os.O_APPEND, 0o644); errOpen == nil {
+				logFile = f
+				defer func() { _ = f.Close() }()
+			}
+		}
+		runCPAPlusUpdate(appDir, logPath, logFile)
+	}()
+
+	c.JSON(http.StatusAccepted, gin.H{"status": "started", "message": "已开始后台更新，服务会自动重启，请稍后刷新页面"})
+}
+
+func latestReleaseVersionFromURL(rawURL string) string {
+	parsed, err := url.Parse(rawURL)
+	if err != nil {
+		return ""
+	}
+	const marker = "/releases/tag/"
+	idx := strings.LastIndex(parsed.Path, marker)
+	if idx < 0 {
+		return ""
+	}
+	tag := parsed.Path[idx+len(marker):]
+	if decoded, errUnescape := url.PathUnescape(tag); errUnescape == nil {
+		tag = decoded
+	}
+	return strings.TrimSpace(tag)
+}
+
+func latestCommitFromAtom(body []byte) (string, error) {
+	match := gitHubCommitIDPattern.FindSubmatch(body)
+	if len(match) < 2 {
+		return "", fmt.Errorf("missing latest commit in atom feed")
+	}
+	return strings.ToLower(string(match[1])), nil
+}
 
