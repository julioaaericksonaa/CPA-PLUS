+func pickSample(items []account, sampleSize int) []account {
+	if sampleSize <= 0 || sampleSize >= len(items) {
+		out := make([]account, len(items))
+		copy(out, items)
+		return out
+	}
+	out := make([]account, len(items))
+	copy(out, items)
+	rand.Shuffle(len(out), func(i, j int) {
+		out[i], out[j] = out[j], out[i]
+	})
+	return out[:sampleSize]
+}
