+func TestCPAPlusReleaseStatusDetectsSameBinary(t *testing.T) {
+	dir := t.TempDir()
+	binary := filepath.Join(dir, "cli-proxy-api")
+	content := []byte("same-binary")
+	if err := os.WriteFile(binary, content, 0o755); err != nil {
+		t.Fatalf("write binary: %v", err)
+	}
+	sha := fmt.Sprintf("%x", sha256.Sum256(content))
+
+	changed, current, err := cpaPlusReleaseChanged(binary, sha+"  CLIProxyAPI-linux-amd64\n")
+	if err != nil {
+		t.Fatalf("cpaPlusReleaseChanged returned error: %v", err)
+	}
+	if changed {
+		t.Fatal("changed = true, want false for identical sha")
+	}
+	if current != sha {
+		t.Fatalf("current sha = %q, want %q", current, sha)
+	}
+}
+
+func TestCPAPlusReleaseStatusDetectsDifferentBinary(t *testing.T) {
+	dir := t.TempDir()
+	binary := filepath.Join(dir, "cli-proxy-api")
+	if err := os.WriteFile(binary, []byte("old-binary"), 0o755); err != nil {
+		t.Fatalf("write binary: %v", err)
+	}
+
+	changed, _, err := cpaPlusReleaseChanged(binary, "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa  CLIProxyAPI-linux-amd64\n")
+	if err != nil {
+		t.Fatalf("cpaPlusReleaseChanged returned error: %v", err)
+	}
+	if !changed {
+		t.Fatal("changed = false, want true for different sha")
+	}
+}
+
+func TestCPAPlusUpdateStateRejectsConcurrentStart(t *testing.T) {
+	state := &cpaPlusUpdateState{}
+	if !state.tryStart() {
+		t.Fatal("first tryStart() = false, want true")
+	}
+	if state.tryStart() {
+		t.Fatal("second tryStart() = true, want false while running")
+	}
+	state.finish()
+	if !state.tryStart() {
+		t.Fatal("tryStart() after finish = false, want true")
+	}
+}
+
+func TestCPAPlusSystemdRunCommandDetachesFromCurrentService(t *testing.T) {
+	appDir := "/root/apps/cliproxyapi-plus"
+	logPath := "/root/apps/cliproxyapi-plus/logs/cpa-plus-update.log"
+	name, args := cpaPlusSystemdRunCommand(appDir, logPath)
+	if name != "systemd-run" {
