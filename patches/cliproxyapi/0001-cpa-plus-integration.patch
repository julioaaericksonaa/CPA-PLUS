+}
+
+type UsageStore interface {
+	UsageSummary(store.UsageQuery) (store.UsagePayload, error)
+	ImportUsageEvents([]store.UsageEvent) (store.UsageImportResult, error)
+	ExportUsageEvents(store.UsageQuery) ([]store.UsageEvent, error)
+	ListUsageEvents(store.UsageQuery) ([]store.UsageEvent, bool, error)
+}
+
+type Options struct {
+	Enabled         bool
+	Store           any
+	Collector       CollectorStatusProvider
+	ManagerConfig   *managerconfig.Service
+	CodexInspection *codexinspection.Service
+	Auth            []gin.HandlerFunc
+}
+
+func RegisterRoutes(group *gin.RouterGroup, opts Options) {
+	if group == nil || !opts.Enabled {
+		return
+	}
+
+	group.GET("/status", func(c *gin.Context) {
+		collectorStatus := collector.Status{Collector: "stopped", Mode: "auto", Queue: "redisqueue"}
+		if opts.Collector != nil {
+			collectorStatus = opts.Collector.Status()
+		}
+		c.JSON(http.StatusOK, gin.H{
+			"status":      "ok",
+			"service":     "cpa-manager-plus",
+			"mode":        "integrated",
+			"collector":   collectorStatus,
+			"deadLetters": collectorStatus.DeadLetters,
+		})
+	})
+	group.GET("/info", func(c *gin.Context) {
+		c.JSON(http.StatusOK, gin.H{
+			"integrated":    true,
+			"setupRequired": false,
+		})
+	})
+	group.GET("/collector/status", func(c *gin.Context) {
+		handleCollectorStatus(c, opts.Collector)
+	})
+	RegisterModelPriceRoutes(group, opts)
+	RegisterAPIKeyAliasRoutes(group, opts)
+	RegisterUsageRoutes(group, opts)
+}
+
+func handleCollectorStatus(c *gin.Context, provider CollectorStatusProvider) {
+	if provider == nil {
+		c.JSON(http.StatusOK, collector.Status{
+			Collector: "stopped",
+			Mode:      "auto",
+			Queue:     "redisqueue",
+		})
+		return
+	}
+	c.JSON(http.StatusOK, provider.Status())
+}
+
+func RegisterCompatibilityRoutes(engine *gin.Engine, opts Options) {
+	if engine == nil || !opts.Enabled {
+		return
+	}
+	engine.GET("/usage-service/info", func(c *gin.Context) {
+		c.JSON(http.StatusOK, gin.H{
+			"service":            "cpa-manager-plus",
+			"mode":               "integrated",
+			"configured":         true,
+			"projectInitialized": true,
+			"setupRequired":      false,
+			"adminReady":         true,
+			"dataKeyReady":       true,
+		})
+	})
+	engine.GET("/status", func(c *gin.Context) {
+		c.JSON(http.StatusOK, gin.H{
+			"service": "cpa-manager-plus",
+			"mode":    "integrated",
+		})
+	})
+	configHandlers := append([]gin.HandlerFunc{}, opts.Auth...)
+	configHandlers = append(configHandlers, func(c *gin.Context) {
+		if opts.ManagerConfig == nil {
+			c.JSON(http.StatusOK, integratedManagerConfigResponse(c.Request.Context(), nil))
+			return
+		}
+		if c.Request.Method == http.MethodPut {
+			var req struct {
+				Config store.ManagerConfig `json:"config"`
+			}
+			if err := c.ShouldBindJSON(&req); err != nil {
+				c.JSON(http.StatusBadRequest, gin.H{"error": "invalid JSON"})
+				return
+			}
+			res, err := opts.ManagerConfig.Update(c.Request.Context(), req.Config)
+			if err != nil {
+				c.JSON(http.StatusBadRequest, gin.H{"error": err.Error()})
+				return
+			}
+			c.JSON(http.StatusOK, res)
+			return
+		}
+		res, err := opts.ManagerConfig.Get(c.Request.Context())
+		if err != nil {
+			c.JSON(http.StatusInternalServerError, gin.H{"error": err.Error()})
+			return
+		}
+		c.JSON(http.StatusOK, res)
+	})
+	engine.GET("/usage-service/config", configHandlers...)
+	engine.PUT("/usage-service/config", configHandlers...)
+}
+
+func integratedManagerConfigResponse(ctx context.Context, svc *managerconfig.Service) gin.H {
+	if svc != nil {
+		res, err := svc.Get(ctx)
+		if err == nil {
+			return gin.H{"source": res.Source, "config": res.Config, "cpaUsage": res.CPAUsage}
+		}
+	}
+	return gin.H{
+		"source": "integrated",
+		"config": gin.H{
+			"cpaConnection": gin.H{
+				"cpaBaseUrl":    "integrated",
+				"managementKey": "integrated",
+			},
+			"collector": gin.H{
+				"enabled":        true,
+				"collectorMode":  "auto",
+				"queue":          "redisqueue",
+				"popSide":        "left",
+				"batchSize":      100,
+				"pollIntervalMs": 1000,
+				"queryLimit":     50000,
+			},
+			"codexInspection": store.DefaultCodexInspectionConfig(),
+			"externalUsageService": gin.H{
+				"enabled":     false,
+				"serviceBase": "",
+			},
+		},
+		"cpaUsage": gin.H{
+			"usageStatisticsEnabled":          true,
+			"redisUsageQueueRetentionSeconds": 60,
+			"retentionSourceDefault":          true,
+		},
+	}
+}
+
+func RegisterCodexInspectionRoutes(group *gin.RouterGroup, opts Options) {
+	if group == nil || !opts.Enabled {
+		return
+	}
+	group.GET("/codex-inspection/runs", func(c *gin.Context) {
+		if opts.CodexInspection == nil {
+			c.JSON(http.StatusServiceUnavailable, gin.H{"error": "codex inspection service unavailable"})
+			return
+		}
+		limit := 20
+		if raw := strings.TrimSpace(c.Query("limit")); raw != "" {
+			if parsed, err := strconv.Atoi(raw); err == nil && parsed > 0 {
+				limit = parsed
+			}
+		}
+		runs, err := opts.CodexInspection.ListRuns(c.Request.Context(), limit)
+		if err != nil {
+			c.JSON(http.StatusInternalServerError, gin.H{"error": err.Error()})
+			return
+		}
+		c.JSON(http.StatusOK, gin.H{"items": runs})
+	})
+	group.POST("/codex-inspection/run", func(c *gin.Context) {
+		if opts.CodexInspection == nil {
+			c.JSON(http.StatusServiceUnavailable, gin.H{"error": "codex inspection service unavailable"})
+			return
+		}
+		result, err := opts.CodexInspection.Run(context.WithoutCancel(c.Request.Context()), codexinspection.RunRequest{TriggerType: "manual", TriggerKey: "manual"})
+		if err != nil {
+			c.JSON(codexInspectionErrorStatus(err), gin.H{"error": err.Error()})
+			return
+		}
+		c.JSON(http.StatusOK, result)
+	})
+	group.GET("/codex-inspection/runs/:id", func(c *gin.Context) {
+		if opts.CodexInspection == nil {
+			c.JSON(http.StatusServiceUnavailable, gin.H{"error": "codex inspection service unavailable"})
+			return
+		}
+		id, err := strconv.ParseInt(c.Param("id"), 10, 64)
+		if err != nil || id <= 0 {
+			c.JSON(http.StatusBadRequest, gin.H{"error": "run id is required"})
+			return
+		}
+		detail, err := opts.CodexInspection.GetRun(c.Request.Context(), id)
+		if err != nil {
+			c.JSON(codexInspectionErrorStatus(err), gin.H{"error": err.Error()})
+			return
+		}
+		c.JSON(http.StatusOK, detail)
+	})
+	group.POST("/codex-inspection/runs/:id/actions", func(c *gin.Context) {
+		if opts.CodexInspection == nil {
+			c.JSON(http.StatusServiceUnavailable, gin.H{"error": "codex inspection service unavailable"})
+			return
+		}
+		id, err := strconv.ParseInt(c.Param("id"), 10, 64)
+		if err != nil || id <= 0 {
+			c.JSON(http.StatusBadRequest, gin.H{"error": "run id is required"})
+			return
+		}
+		var req codexinspection.ExecuteActionsRequest
+		if err := c.ShouldBindJSON(&req); err != nil {
+			c.JSON(http.StatusBadRequest, gin.H{"error": "invalid JSON"})
+			return
+		}
+		result, err := opts.CodexInspection.ExecuteManualActions(c.Request.Context(), id, req)
+		if err != nil {
+			c.JSON(codexInspectionErrorStatus(err), gin.H{"error": err.Error()})
+			return
+		}
+		c.JSON(http.StatusOK, result)
+	})
+}
+
+func codexInspectionErrorStatus(err error) int {
+	switch {
+	case errors.Is(err, codexinspection.ErrRunNotFound):
+		return http.StatusNotFound
+	case errors.Is(err, codexinspection.ErrRunAlreadyActive), errors.Is(err, codexinspection.ErrRunNotCompleted):
+		return http.StatusConflict
+	case errors.Is(err, codexinspection.ErrNotConfigured):
+		return http.StatusPreconditionFailed
+	case errors.Is(err, codexinspection.ErrActionIDsRequired), errors.Is(err, codexinspection.ErrNoActionableResults):
+		return http.StatusBadRequest
+	default:
+		return http.StatusInternalServerError
+	}
+}
