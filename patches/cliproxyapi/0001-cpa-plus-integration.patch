+func runCPAPlusUpdate(appDir string, logPath string, logFile *os.File) {
+	ctx, cancel := context.WithTimeout(context.Background(), 90*time.Minute)
+	defer cancel()
+
+	if cpaPlusSystemdRunAvailable() {
+		name, args := cpaPlusSystemdRunCommand(appDir, logPath)
+		cmd := exec.CommandContext(ctx, name, args...)
+		cmd.Env = cpaPlusSelfUpdateEnv(os.Environ())
+		if logFile != nil {
+			cmd.Stdout = logFile
+			cmd.Stderr = logFile
+		}
+		if errRun := cmd.Run(); errRun == nil {
+			return
+		} else {
+			log.WithError(errRun).Warn("CPA-PLUS systemd-run update launch failed; falling back to direct update")
+		}
+	}
+
+	cmd := exec.CommandContext(ctx, cpaPlusUpdateCommand)
+	cmd.Dir = appDir
+	cmd.Env = cpaPlusSelfUpdateEnv(os.Environ())
+	if logFile != nil {
+		cmd.Stdout = logFile
+		cmd.Stderr = logFile
+	}
+	if errRun := cmd.Run(); errRun != nil {
+		log.WithError(errRun).Warn("CPA-PLUS background update failed")
+	}
+}
+
+func cpaPlusSystemdRunAvailable() bool {
+	if _, err := exec.LookPath("systemd-run"); err != nil {
+		return false
+	}
+	if _, err := os.Stat("/run/systemd/system"); err != nil {
+		return false
+	}
+	return true
+}
+
+func cpaPlusReleaseNotReadyHTTPStatus() int {
+	return http.StatusOK
+}
+
+func cpaPlusSelfUpdateEnv(base []string) []string {
+	env := make([]string, 0, len(base)+1)
+	for _, item := range base {
+		if strings.HasPrefix(item, "CPA_PLUS_SYSTEMD=") {
+			continue
+		}
+		env = append(env, item)
+	}
+	return append(env, "CPA_PLUS_SYSTEMD=0")
+}
+
+func cpaPlusSystemdRunCommand(appDir string, logPath string) (string, []string) {
+	return "systemd-run", []string{
+		fmt.Sprintf("--unit=cpa-plus-self-update-%d", time.Now().UnixNano()),
+		"--collect",
+		"--property=Type=oneshot",
+		"--property=RuntimeMaxSec=90min",
+		"--setenv=CPA_PLUS_SYSTEMD=0",
+		"--working-directory=" + appDir,
+		"/bin/sh",
+		"-c",
+		`exec "$1" >> "$2" 2>&1`,
+		"cpa-plus-update",
+		cpaPlusUpdateCommand,
+		logPath,
+	}
+}
+
+func cpaPlusReleaseChanged(binaryPath string, releaseSHAText string) (bool, string, error) {
+	releaseSHA := releaseSHAFromText(releaseSHAText)
+	if releaseSHA == "" {
+		return false, "", fmt.Errorf("missing release sha256")
+	}
+	currentSHA, err := fileSHA256(binaryPath)
+	if err != nil {
+		if os.IsNotExist(err) {
+			return true, "", nil
+		}
+		return false, "", err
+	}
+	return !strings.EqualFold(currentSHA, releaseSHA), currentSHA, nil
+}
+
+func releaseSHAFromText(text string) string {
+	scanner := bufio.NewScanner(strings.NewReader(text))
+	if scanner.Scan() {
+		fields := strings.Fields(scanner.Text())
+		if len(fields) > 0 {
+			return strings.ToLower(strings.TrimSpace(fields[0]))
+		}
+	}
+	return ""
+}
+
+func fileSHA256(path string) (string, error) {
+	f, err := os.Open(path)
+	if err != nil {
+		return "", err
+	}
+	defer func() { _ = f.Close() }()
+	sum := sha256.New()
+	if _, errCopy := io.Copy(sum, f); errCopy != nil {
+		return "", errCopy
+	}
+	return fmt.Sprintf("%x", sum.Sum(nil)), nil
 }
 
