+func shortVersionCommit(value string) string {
+	trimmed := strings.TrimSpace(value)
+	if len(trimmed) > 8 {
+		return trimmed[:8]
+	}
+	return trimmed
+}
+
+func versionWithCommit(version string, commit string) string {
+	short := shortVersionCommit(commit)
+	trimmedVersion := strings.TrimSpace(version)
+	if trimmedVersion == "" {
+		return short
+	}
+	if short == "" {
+		return trimmedVersion
+	}
+	return trimmedVersion + "+" + short
+}
