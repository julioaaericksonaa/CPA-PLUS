+func (s *Server) initPlusManagerServices() {
+	if s == nil || s.cfg == nil || !s.cfg.PlusManager.Enabled {
+		return
+	}
+	st := s.openPlusStore()
+	if st == nil {
+		return
+	}
+	baseURL := fmt.Sprintf("http://127.0.0.1:%d", s.cfg.Port)
+	key := strings.TrimSpace(s.internalManagementPassword)
+	if key == "" {
+		key = generateInternalManagementPassword()
+		s.internalManagementPassword = key
+		if s.mgmt != nil {
+			s.mgmt.SetLocalPassword(key)
+		}
+	}
+	s.plusManagerConfig = plusmanagerconfig.New(s.cfg, st, baseURL, key)
+	s.plusCodexInspection = pluscodexinspection.New(st, s.plusManagerConfig)
+}
+
+func (s *Server) openPlusStore() *plusstore.Store {
+	if s == nil || s.cfg == nil || !s.cfg.PlusManager.Enabled {
+		return nil
+	}
+	if s.plusStore != nil {
+		return s.plusStore
+	}
+	dbPath := strings.TrimSpace(s.cfg.PlusManager.DBPath)
+	if dbPath == "" {
+		return nil
+	}
+	dbDir := filepath.Dir(dbPath)
+	if dbDir != "" && dbDir != "." {
+		if err := os.MkdirAll(dbDir, 0o755); err != nil {
+			log.WithError(err).Warn("failed to prepare Plus manager data directory")
+			return nil
+		}
+	}
+	store, err := plusstore.Open(dbPath)
+	if err != nil {
+		log.WithError(err).Warn("failed to open Plus manager store")
+		return nil
+	}
+	s.plusStore = store
+	return store
+}
+
+func plusCollectorConfigured(cfg *config.Config) bool {
+	return cfg != nil && cfg.PlusManager.Enabled && cfg.PlusManager.CollectorEnabled
+}
+
+func (s *Server) startPlusCollector() {
+	if s == nil || s.plusCollector != nil || !plusCollectorConfigured(s.cfg) {
+		return
+	}
+	usageStore := s.openPlusStore()
+	if usageStore == nil {
+		return
+	}
+	interval := time.Duration(s.cfg.PlusManager.PollIntervalMs) * time.Millisecond
+	s.plusCollector = pluscollector.New(pluscollector.Config{
+		Mode:         s.cfg.PlusManager.CollectorMode,
+		QueueName:    "redisqueue",
+		BatchSize:    100,
+		PollInterval: interval,
+	}, pluscollector.RedisQueue{}, usageStore)
+	s.plusCollector.Start(context.Background())
+}
+
+func (s *Server) stopPlusCollector(ctx context.Context) {
+	if s == nil || s.plusCollector == nil {
+		return
+	}
+	if err := s.plusCollector.Stop(ctx); err != nil {
+		log.Debugf("failed to stop Plus usage collector: %v", err)
+	}
+	s.plusCollector = nil
+}
+
+func (s *Server) startPlusCodexInspectionWorker() {
+	if s == nil || s.plusCodexWorkerCancel != nil || s.plusCodexInspection == nil || s.openPlusStore() == nil {
+		return
+	}
+	ctx, cancel := context.WithCancel(context.Background())
+	s.plusCodexWorkerCancel = cancel
+	plusworker.NewCodexInspectionWorker(s.openPlusStore(), s.plusCodexInspection).Start(ctx)
