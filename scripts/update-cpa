#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<USAGE
Usage: update-cpa [install-release options]

Update CPA-PLUS from the latest published GitHub Release, replace the local
binary, keep config.yaml/data/logs, and restart the service.

Common examples:
  update-cpa
  CPA_PLUS_RELEASE=latest update-cpa
  CPA_PLUS_APP_DIR=/root/apps/cliproxyapi-plus update-cpa

This command does not build locally. For source builds, use scripts/update-linux.sh
or scripts/build-linux-binary.sh from a local checkout.
USAGE
}

case "${1:-}" in
  -h|--help|help)
    usage
    exit 0
    ;;
esac

REPO="${CPA_PLUS_REPO:-julioaaericksonaa/CPA-PLUS}"
REF="${CPA_PLUS_INSTALL_REF:-latest}"

if command -v gh >/dev/null 2>&1 && gh auth status --hostname github.com >/dev/null 2>&1; then
  gh api "repos/${REPO}/contents/scripts/install-release.sh?ref=${REF}" --jq .content | base64 -d | bash -s -- "$@"
else
  if ! command -v curl >/dev/null 2>&1; then
    echo "Missing curl. Install curl or login with GitHub CLI: gh auth login" >&2
    exit 1
  fi
  curl -fsSL "https://raw.githubusercontent.com/${REPO}/${REF}/scripts/install-release.sh" | bash -s -- "$@"
fi
