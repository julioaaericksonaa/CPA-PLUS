#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<USAGE
Usage: update-cpa [build options]

Pull the CPA-PLUS linux maintenance branch, sync upstream CLIProxyAPI and
CPA-Manager-Plus, rebuild the Linux binary, install it to /root/apps/cliproxyapi-plus,
and restart the service on port 8317.

Environment:
  CPA_PLUS_REPO_DIR      Local linux branch checkout. Default: /root/.config/superpowers/worktrees/CLIProxyAPI/auto
  CPA_PLUS_APP_DIR       Install directory. Default: /root/apps/cliproxyapi-plus
  CPA_PLUS_PORT          Service port. Default: 8317
  CPA_PLUS_SKIP_TESTS    Default: 1
USAGE
}

case "${1:-}" in
  -h|--help|help)
    usage
    exit 0
    ;;
esac

REPO_DIR="${CPA_PLUS_REPO_DIR:-/root/.config/superpowers/worktrees/CLIProxyAPI/auto}"
BRANCH="${CPA_PLUS_BRANCH:-linux}"
APP_DIR="${CPA_PLUS_APP_DIR:-/root/apps/cliproxyapi-plus}"
PORT="${CPA_PLUS_PORT:-8317}"

if [[ ! -d "${REPO_DIR}/.git" && ! -f "${REPO_DIR}/.git" ]]; then
  echo "CPA-PLUS linux repository not found: ${REPO_DIR}" >&2
  echo "Set CPA_PLUS_REPO_DIR to your local CPA-PLUS linux branch checkout." >&2
  exit 1
fi

cd "${REPO_DIR}"

echo "==> Updating CPA-PLUS maintenance branch (${BRANCH})"
git fetch origin "${BRANCH}"
git checkout "${BRANCH}"
git reset --hard "origin/${BRANCH}"

echo "==> Building from upstream and restarting CPA-PLUS"
CPA_PLUS_APP_DIR="${APP_DIR}" \
CPA_PLUS_PORT="${PORT}" \
CPA_PLUS_SKIP_TESTS="${CPA_PLUS_SKIP_TESTS:-1}" \
  "${REPO_DIR}/scripts/update-linux.sh" --skip-tests "$@"

echo "==> CPA-PLUS updated. Open http://host:${PORT}/management.html and press Ctrl+F5 if the old panel is cached."
